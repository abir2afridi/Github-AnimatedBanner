{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "npm run dev:bannerforge",
    "dev:all": "concurrently -k -n bannerforge,api -c blue,green \"npm run dev:bannerforge\" \"npm run dev:api\"",
    "dev:bannerforge": "npx pnpm --filter @workspace/bannerforge dev",
    "dev:api": "npx pnpm --filter @workspace/api-server dev",
    "dev:sandbox": "npx pnpm --filter @workspace/mockup-sandbox dev",
    "build": "npm run typecheck && npm run build:workspaces",
    "build:workspaces": "npm run build --workspaces --if-present",
    "typecheck:libs": "tsc --build",
    "typecheck": "npm run typecheck:libs && npm run typecheck --workspaces --if-present"
  },
  "private": true,
  "devDependencies": {
    "@vercel/node": "^5.3.7",
    "@types/node": "^25.3.3",
    "concurrently": "^9.2.1",
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
