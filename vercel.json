{
  "buildCommand": "cd artifacts/bannerforge && npx pnpm build",
  "outputDirectory": "artifacts/bannerforge/dist/public",
  "installCommand": "npx pnpm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "BASE_PATH": "/"
  }
}
