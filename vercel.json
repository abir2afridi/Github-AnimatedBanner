{
  "buildCommand": "npx pnpm build",
  "installCommand": "npx pnpm install",
  "outputDirectory": "artifacts/bannerforge/dist/public",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
